# NOON 数据分析系统 - 环境变量配置模板
# 复制此文件为 .env 并填写实际值: cp .env.example .env

# ── 应用 ──
DEBUG=True

# ── PostgreSQL (生产环境) ──
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/noon_data

# ── SQLite (开发环境，无需额外安装数据库) ──
DATABASE_URL=sqlite+aiosqlite:///./noon_data.db

# ── ClickHouse ──
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=noon_analytics

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Oxylabs API (需要注册获取) ──
# 注册地址: https://oxylabs.io/
OXYLABS_USERNAME=your_username
OXYLABS_PASSWORD=your_password

# ── Webhook 安全密钥 ──
WEBHOOK_SECRET=noon-webhook-secret-change-me
