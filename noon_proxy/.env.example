# NOON Base Auth Proxy - Environment Configuration Template
# 复制此文件为 .env 并填入实际值: cp .env.example .env

# 登录凭据
NOON_USER=admin
NOON_PASS=your_strong_password_here

# Session secret（使用 openssl rand -hex 32 生成强随机密钥）
SESSION_SECRET=generate_a_strong_random_secret_here

# 代理服务配置
PORT=3000
API_URL=http://127.0.0.1:8001
STATIC_DIR=/home/san/noon_base/noon_dashboard/dist

# Session 有效期，单位毫秒（默认 30 分钟）
SESSION_MAX_AGE=1800000

# Cookie Secure 标志（生产环境必须为 true，要求 HTTPS；本地 HTTP 测试可临时设为 false）
SECURE_COOKIE=true
